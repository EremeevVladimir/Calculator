<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.MainActivity">

    <ImageView
        android:id="@+id/imageView3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:cropToPadding="true"
        android:scaleType="centerCrop"
        app:srcCompat="@drawable/winter1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="12dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/calculator_display"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:ems="40"
            android:gravity="end|bottom"
            android:minHeight="78dp"
            android:textStyle="bold"
            android:textSize="@dimen/output_text_size"
            android:layout_weight="2"
            android:text="0" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginTop="20dp"
            android:useDefaultMargins="true"
            android:columnCount="7">
            <Button
                android:id="@+id/key_ac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_ac"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_del"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_del"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_percent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_percent"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_divide"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_divide"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_7"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_7"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_8"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_8"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_9"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_9"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_multiplication"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_multiplication"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_4"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_5"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_6"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_minus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_minus"
                android:textColor="@color/input_button_text_color" />

            <Button
                android:id="@+id/key_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_1"
                android:textColor="@color/input_button_text_color" />

            <Button
                android:id="@+id/key_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_2"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_3"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_plus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_plus"
                android:textColor="@color/input_button_text_color" />

            <Button
                android:id="@+id/key_0"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_0"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_comma"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_comma"
                android:textColor="@color/input_button_text_color" />
            <Button
                android:id="@+id/key_equals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="@color/input_button_background_color"
                android:textStyle="bold"
                android:textSize="@dimen/input_text_size"
                android:text="@string/key_equals"
                android:layout_columnSpan="2"
                android:layout_gravity="fill_horizontal"
                android:textColor="@color/input_button_text_color" />

        </GridLayout>



    </LinearLayout>

</FrameLayout>